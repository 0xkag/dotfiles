{
  "autoUpdatesChannel": "latest",
  "awsAuthRefresh": "rm -rf ~/.aws/cli/cache/* 2>/dev/null; aws sts get-caller-identity",
  "permissions": {
    "allow": [
      "Bash(ldapsearch:*)"
    ],
    "deny": [
      "Bash(rm *)",
      "Bash(rm)",
      "Bash(sts *)",
      "Bash(sts)"
    ]
  },
  "model": "us.anthropic.claude-opus-4-8[1m]",
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "printf '\\a' > \"$(tmux display -p -t \"$TMUX_PANE\" '#{pane_tty}')\""
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "printf '\\a' > \"$(tmux display -p -t \"$TMUX_PANE\" '#{pane_tty}')\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "printf '\\a' > \"$(tmux display -p -t \"$TMUX_PANE\" '#{pane_tty}')\""
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "claude-statusline"
  },
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true,
    "gitlab@claude-plugins-official": true,
    "caveman@caveman": false,
    "ponytail@ponytail": true
  },
  "extraKnownMarketplaces": {
    "caveman": {
      "source": {
        "source": "github",
        "repo": "JuliusBrussee/caveman"
      }
    },
    "ponytail": {
      "source": {
        "source": "github",
        "repo": "DietrichGebert/ponytail"
      }
    }
  },
  "skipWebFetchPreflight": true,
  "effortLevel": "medium",
  "skipWorkflowUsageWarning": true,
  "theme": "dark",
  "editorMode": "normal",
  "mcpServers": {}
}
