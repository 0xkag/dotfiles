{
  "autoUpdatesChannel": "latest",
  "awsAuthRefresh": "rm -rf ~/.aws/cli/cache/* 2>/dev/null; aws sts get-caller-identity",
  "permissions": {
    "allow": [
      "Bash(ldapsearch:*)"
    ],
    "deny": [
      "Bash(rm *)",
      "Bash(rm)",
      "Bash(sts *)",
      "Bash(sts)"
    ]
  },
  "model": "us.anthropic.claude-opus-4-7[1m]",
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "tmux new-window -d 'printf \"\\a\"; sleep 2'"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "tmux new-window -d 'printf \"\\a\"; sleep 2'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "tmux new-window -d 'printf \"\\a\"; sleep 2'"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "claude-statusline"
  },
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true,
    "gitlab@claude-plugins-official": true,
    "caveman@caveman": true
  },
  "extraKnownMarketplaces": {
    "caveman": {
      "source": {
        "source": "github",
        "repo": "JuliusBrussee/caveman"
      }
    }
  },
  "effortLevel": "medium",
  "autoUpdatesChannel": "latest",
  "theme": "dark-ansi",
  "mcpServers": {}
}
