#!/bin/bash

input=$(cat)
cwd=$(echo "$input" | jq -r '.workspace.current_dir')
user=$(whoami)
host=$(hostname -s)
git_info=$(cd "$cwd" 2>/dev/null && git rev-parse --abbrev-ref HEAD 2>/dev/null | sed 's/.*/git:(\0)/')

# Credential-expired warning, prepended only when the sandbox refresh loop has
# written the sentinel.  Harmless outside the sandbox where the file is absent.
cred_warn=''
if [ -f "${HOME}/.aws/CREDENTIAL_EXPIRED" ]; then
    cred_warn=$'\033[1;31mCREDS EXPIRED: kinit + run --push-creds\033[0m '
fi

printf "%s\033[1;32m%s@%s:\033[0;36m%s\033[1;34m%s\033[0m" "$cred_warn" "$user" "$host" "$cwd" "${git_info:+ $git_info}"
