#!/usr/bin/env bash

# clip-in: copy stdin to system clipboard (multi-platform)

if [ -n "${WAYLAND_DISPLAY:-}" ] && command -v wl-copy &> /dev/null; then
    wl-copy
elif [ -n "${DISPLAY:-}" ] && command -v xclip &> /dev/null; then
    xclip -selection clipboard -i
elif [ -n "${DISPLAY:-}" ] && command -v xsel &> /dev/null; then
    xsel --clipboard --input
elif grep -qi microsoft /proc/version 2> /dev/null; then
    clip.exe
elif [ -n "${TMUX:-}" ]; then
    tmux load-buffer -w -
elif [ -e /dev/tty ]; then
    # OSC 52 fallback -- write clipboard escape sequence directly to the
    # terminal.  Works over SSH if the terminal chain supports OSC 52 (e.g.
    # Windows Terminal, gnome-terminal; not PuTTY).
    data=$(base64 | tr -d '\n')
    printf '\033]52;c;%s\a' "$data" > /dev/tty
else
    echo "clip-in: no clipboard provider found" >&2
    exit 1
fi
